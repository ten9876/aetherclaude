<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.aetherclaude.cloudflared</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/cloudflared</string>
        <string>--no-autoupdate</string>
        <string>--config</string>
        <string>/Users/aetherclaude/.cloudflared/config.yml</string>
        <string>tunnel</string>
        <string>run</string>
    </array>
    <key>UserName</key>
    <string>aetherclaude</string>
    <key>KeepAlive</key>
    <true/>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Users/aetherclaude/logs/cloudflared.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/aetherclaude/logs/cloudflared-error.log</string>
</dict>
</plist>
