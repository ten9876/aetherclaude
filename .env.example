# AetherClaude environment — copy to ~/.env and fill in
#
#   cp .env.example ~/.env
#   chmod 600 ~/.env
#
# ~/.env is sourced by run-agent.sh and loaded by the Python services
# (tetragon-dashboard.py, eslogger-bridge.py). DO NOT commit it.

# GitHub App numeric ID — get this from your App's settings page
GITHUB_APP_ID=

# HMAC secret used to verify GitHub webhooks to the dashboard
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=
